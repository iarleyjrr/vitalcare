{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install flask==3.1.0 gunicorn==21.2.0"
  },
  "deploy": {
    "startCommand": "gunicorn --chdir backend app:app --bind 0.0.0.0:$PORT --workers 1 --timeout 120",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
